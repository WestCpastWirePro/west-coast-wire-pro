# ─────────────────────────────────────────────────────────────
# West Coast Wire Pro — Environment Variables
# ─────────────────────────────────────────────────────────────
# INSTRUCTIONS:
# 1. Copy this file and rename it to: .env.local
# 2. Fill in each value (see SETUP_GUIDE.md for where to find them)
# 3. NEVER commit .env.local to GitHub — it's already in .gitignore
# ─────────────────────────────────────────────────────────────

# ── STRIPE ───────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys

# Secret key (starts with sk_test_ for testing, sk_live_ for real payments)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret (starts with whsec_)
# Found in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Your product Price IDs (starts with price_)
# Found in: Stripe Dashboard → Products → click product → copy Price ID
STRIPE_PRICE_STANDARD=price_REPLACE_ME
STRIPE_PRICE_PRO=price_REPLACE_ME

# ── WIREREADY ACCESS CODES ────────────────────────────────────
# A random secret used to sign access codes — make this long and random
# Generate one at: https://generate-secret.vercel.app/32
# Or just mash your keyboard for 30+ characters
WIREREADY_ACCESS_SECRET=replace-with-a-long-random-string-you-made-up

# ── OPTIONAL: EMAIL (for sending access codes by email) ───────
# Uncomment when you add email sending to api/webhook.js
# RESEND_API_KEY=re_REPLACE_ME
